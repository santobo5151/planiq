# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and stays local to your machine.

# --- Supabase ---
# Project URL and anon key are safe to expose to the browser (NEXT_PUBLIC_*).
# Find them in Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key bypasses RLS — never expose this to the browser.
# Used only by src/lib/supabase/admin.ts (server-only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (transactional email) ---
# Get an API key at https://resend.com → API Keys.
RESEND_API_KEY=your-resend-api-key

# --- Anthropic (AI plan generation) ---
# Server-only. Do NOT prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
